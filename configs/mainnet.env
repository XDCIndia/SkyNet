# XDC Mainnet Configuration
# Network: XDC Mainnet
# Chain ID: 50

NETWORK=mainnet
CHAIN_ID=50

# Bootnodes
BOOTNODES=enode://1c20e6b46ce608c1fe739e78691227b2a174e0d9e79d5ef9a72c8069931057b73e7dbad8a55d2a123658f520a47888d2657314b7c9a55569e2db5e89f1e288dd@5.189.144.192:30303,enode://1c20e6b46ce608c1fe739e78691227b2a174e0d9e79d5ef9a72c8069931057b73e7dbad8a55d2a123658f520a47888d2657314b7c9a55569e2db5e89f1e288dd@88.99.97.197:30303

# Ports
RPC_PORT=8545
WS_PORT=8546
P2P_PORT=30303

# Data directory
DATA_DIR=/root/xdcchain

# Sync mode: full, archive, or snap
SYNC_MODE=full

# Cache size (MB)
CACHE_SIZE=4096

# Enable RPC APIs
RPC_API=eth,net,web3,XDPoS,admin,personal,debug

# Gas price (wei)
GAS_PRICE=1000000000

# Gas limit
GAS_LIMIT=42000000

# Verbosity (0=silent, 1=error, 2=warn, 3=info, 4=debug, 5=detail)
VERBOSITY=3

# Metrics
METRICS_ENABLED=true
METRICS_PORT=6060

# GraphQL (optional)
GRAPHQL_ENABLED=false

# NAT traversal
NAT=any

# Max peers
MAX_PEERS=25

# Min peers
MIN_PEERS=5
