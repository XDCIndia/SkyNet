# XDC Testnet (Apothem) Configuration
# Network: Apothem Testnet
# Chain ID: 51

NETWORK=testnet
CHAIN_ID=51

# Bootnodes (Apothem testnet)
BOOTNODES=enode://9b017d5161f7a735294e4a6c8a76f5ab658a6c8694d3dbbc4fb6b40a18009e4a22b903c590c39859b60294faaaa2b50b6c8310a5ba9a5b7f2c70da7415d3a57@188.166.229.97:30301,enode://8537c73ab20f8942d36f3bb5a9a294b885932f67a43e0dd4b46885b89e159111e69578bc026d8e7f90222f5dbbb2a15853a2f591781a528d78e20d1993b41106@139.59.55.206:30301

# Ports
RPC_PORT=8545
WS_PORT=8546
P2P_PORT=30303

# Data directory
DATA_DIR=/root/xdcchain

# Sync mode: full, archive, or snap
SYNC_MODE=full

# Cache size (MB)
CACHE_SIZE=2048

# Enable RPC APIs
RPC_API=eth,net,web3,XDPoS,admin,personal

# Gas price (wei)
GAS_PRICE=1000000000

# Gas limit
GAS_LIMIT=42000000

# Verbosity (0=silent, 1=error, 2=warn, 3=info, 4=debug, 5=detail)
VERBOSITY=3

# Metrics
METRICS_ENABLED=true
METRICS_PORT=6060

# GraphQL (optional)
GRAPHQL_ENABLED=false

# NAT traversal
NAT=any

# Max peers
MAX_PEERS=15

# Min peers
MIN_PEERS=3
