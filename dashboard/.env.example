# XDCNetOwn Dashboard - Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env files to git!

# Database — Issue #61
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Default port for PostgreSQL is 5432; SkyNet uses 5433 (custom)
# TimescaleDB is required (extends PostgreSQL) for time-series metrics.
#
# Examples:
#   Local (default):  postgresql://skynet:secret@localhost:5433/skynet
#   Docker Compose:   postgresql://skynet:secret@db:5432/skynet
#   Remote/prod:      postgresql://skynet:secret@db.example.com:5432/skynet?sslmode=require
#
# The startup validator (lib/db-validate.ts) checks this at boot and will
# exit with a clear error if the URL is missing, malformed, or unreachable.
DATABASE_URL=postgresql://skynet:your_password_here@localhost:5433/skynet

# RPC Configuration
RPC_URL=http://127.0.0.1:8989

# Monitoring
PROMETHEUS_URL=http://localhost:9090

# WebSocket Server
WS_PORT=3006
NEXT_PUBLIC_WS_URL=ws://localhost:3006
NEXT_PUBLIC_REFRESH_INTERVAL=10

# API Security
# Generate with: openssl rand -hex 32
API_KEYS=your-api-key-1,your-api-key-2
ENABLE_AUTH=true

# Node Configuration
NODE_NAME=xdc-prod-main
PORT=3005

# Telegram Alerts (optional)
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=XDC NetOwn <alerts@xdc.network>
ALERT_EMAIL=admin@example.com
