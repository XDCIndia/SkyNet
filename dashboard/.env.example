# XDCNetOwn Dashboard Environment Variables
# Copy to .env and configure for your environment

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# PostgreSQL Database (uses gateway database with separate netown schema)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5443/xdc_gateway

# API Keys (comma-separated for multiple keys)
# SECURITY: Change these in production!
API_KEYS=your-api-key-here

# =============================================================================
# AUTHENTICATION & RATE LIMITING (Issue #42)
# =============================================================================

# Enable/disable API authentication globally
# When 'false', all API requests are allowed without authentication
# When 'true', valid API key required for most endpoints
ENABLE_AUTH=true

# Enable/disable rate limiting on API endpoints
# When 'true', applies rate limits: public=60/min, authenticated=600/min, heartbeat=120/min
ENABLE_RATE_LIMIT=false

# JWT Secret for WebSocket authentication (min 32 chars)
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Admin API Key for data retention and admin operations
ADMIN_API_KEY=your-admin-api-key-here

# =============================================================================
# RPC & NODE CONNECTIONS
# =============================================================================

# XDC Node RPC Endpoint
RPC_URL=http://127.0.0.1:8989

# Prometheus URL (for node-exporter metrics)
PROMETHEUS_URL=http://localhost:9090

# =============================================================================
# WEBSOCKET SERVER
# =============================================================================

# WebSocket Server Port
WS_PORT=3006

# Public WebSocket URL (for browser connections)
NEXT_PUBLIC_WS_URL=ws://localhost:3006

# WebSocket Authentication (set to 'false' to disable)
REQUIRE_WS_AUTH=true

# =============================================================================
# DASHBOARD SETTINGS
# =============================================================================

# Node name (displayed in dashboard)
NODE_NAME=xdc-node-name

# Next.js port
PORT=3005

# Refresh interval in seconds
NEXT_PUBLIC_REFRESH_INTERVAL=10

# CORS Allowed Origins (comma-separated, defaults to '*')
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005

# =============================================================================
# TELEGRAM ALERTS (Optional)
# =============================================================================

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# =============================================================================
# EMAIL ALERTS - SMTP (Optional)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=XDC NetOwn <alerts@xdc.network>
ALERT_EMAIL=admin@example.com

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Rate Limit Configuration (when ENABLE_RATE_LIMIT=true)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Database Connection Pool
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=10000

# Optional Redis (for caching)
REDIS_URL=redis://localhost:6379

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Feature Toggles
ENABLE_WEBSOCKET=true
ENABLE_METRICS_COLLECTION=true

# Shutdown timeout in milliseconds
SHUTDOWN_TIMEOUT=30000
