# XDCNetOwn Dashboard Environment Variables
# Copy to .env and configure for your environment

# PostgreSQL Database (uses gateway database with separate netown schema)
DATABASE_URL=postgresql://gateway:gateway_secret_2026@localhost:5443/xdc_gateway

# XDC Node RPC Endpoint
RPC_URL=http://127.0.0.1:8989

# Prometheus URL (for node-exporter metrics)
PROMETHEUS_URL=http://localhost:9090

# WebSocket Server Port
WS_PORT=3006

# Node name (displayed in dashboard)
NODE_NAME=xdc-prod-main

# Next.js port
PORT=3005

# Public WebSocket URL (for browser connections)
NEXT_PUBLIC_WS_URL=ws://localhost:3006

# Refresh interval in seconds
NEXT_PUBLIC_REFRESH_INTERVAL=10
