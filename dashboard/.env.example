# XDCNetOwn Dashboard - Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env files to git!

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5433/xdc_gateway

# RPC Configuration
RPC_URL=http://127.0.0.1:8989

# Monitoring
PROMETHEUS_URL=http://localhost:9090

# WebSocket Configuration
WS_PORT=3006
NEXT_PUBLIC_WS_URL=ws://localhost:3006
NEXT_PUBLIC_REFRESH_INTERVAL=10

# Server Configuration
PORT=3005
NODE_NAME=xdc-prod-main

# API Security
# Generate API keys with: openssl rand -hex 32
API_KEYS=your_api_key_1,your_api_key_2
ENABLE_AUTH=true

# Telegram Alerts (optional)
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=XDC NetOwn <alerts@xdc.network>
ALERT_EMAIL=recipient@example.com
