{
  "name": "xdc-skynet-dashboard",
  "version": "0.2.0",
  "description": "XDC SkyNet - Network Ownership Dashboard & Fleet Management for XDC Network",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${PORT:-3005}",
    "build": "next build",
    "start": "next start -p ${PORT:-3005}",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "ws": "tsx ws-server.ts",
    "start:all": "bash start.sh",
    "start:dev": "bash start.sh dev",
    "db:init": "psql $DATABASE_URL -f lib/db/schema.sql",
    "db:migrate": "node scripts/migrate.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.15.6",
    "@amcharts/amcharts5-geodata": "^5.1.5",
    "echarts": "^6.0.0",
    "lucide-react": "^0.563.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "react": "^18",
    "react-dom": "^18",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnilChinchawale/XDCSkyNet.git"
  },
  "keywords": [
    "xdc",
    "blockchain",
    "dashboard",
    "fleet-management",
    "node-monitoring",
    "masternode"
  ],
  "author": "XDC Network",
  "license": "MIT"
}
